# .env.example — 이 파일을 복사해서 .env 를 만들고 실제 값을 채워주세요.
# cp .env.example .env

# Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=handsup_dev
MYSQL_USER=root
MYSQL_ROOT_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_HOST_PASSWORD=

# Kafka (로컬: localhost:29092, 운영: EC2 주소)
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# AWS S3
CLOUD_AWS_CREDENTIALS_ACCESS_KEY=
CLOUD_AWS_CREDENTIALS_SECRET_KEY=
CLOUD_AWS_REGION_STATIC=ap-northeast-2
CLOUD_AWS_S3_BUCKET=handsup-bucket

# JWT
JWT_SECRET=

# Slack
SLACK_WEBHOOK_URL=

# OpenAI
OPENAI_API_KEY=

# Docker Hub (docker-compose 배포 시 사용)
DOCKERHUB_USERNAME=
DOCKERHUB_APP_NAME=
